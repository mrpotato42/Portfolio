---
import Base from "../layouts/Base.astro";
import DarkModeButton from "../components/UI/DarkModeButton.astro";
import Button from "../components/UI/Button.astro";
import LanguageToggle from "../components/UI/LanguageToggle.astro";
import Roadmap from "../components/UI/Roadmap.astro"; // Importamos
import DownloadIcon from "../components/Icons/Download.astro";
import { translations } from "../i18n/translations";

const t = translations.en;

const PROJECTS = [
  {
    date: '2021',
    i18nTitleKey: 'portfolio',
    i18nDescKey: 'portfolioDesc',
    image: 'images/carrousel1.webp',
    href: 'https://mrpotato.netlify.app/',
    state: 'enabled'
  },
  {
    date: '2024-2025',
    i18nTitleKey: 'k4pital',
    i18nDescKey: 'k4pitalDesc',
    image: 'images/carrousel2.webp',
    href: 'https://k4pital.com/',
    state: 'enabled'
  },
  {
    date: '2025-2026',
    i18nTitleKey: 'dolce',
    i18nDescKey: 'dolceDesc',
    image: 'images/carrousel3.webp',
    href: '#',
    state: 'disabled'
  },
  {
    date: '',
    i18nTitleKey: 'linkedin',
    i18nDescKey: 'linkedinDesc',
    image: 'images/carrousel4.webp',
    href: 'https://www.linkedin.com/in/danielcg99',
    state: 'enabled'
  },
  {
    date: '',
    i18nTitleKey: 'github',
    i18nDescKey: 'githubDesc',
    image: 'images/carrousel4.webp',
    href: 'https://github.com/mrpotato42',
    state: 'enabled'
  }
];

const SECTIONS = [
  {

    i18nKey: "professionalWork",
    projects: PROJECTS.slice(0, 3)
  },
  {

    i18nKey: "socialMedia",
    projects: PROJECTS.slice(3, 5)
  }
];
---

<Base>
  <main
    class="flex-1 flex flex-col justify-between text-black font-titillium p-6 sm:p-10 lg:p-1 lg:flex-nowrap lg:m-2 dark:text-dark-text"
  >
    <divHead class="flex shrink-0 flex-row mb-6 mt-4 justify-between">
      <div class="flex-col w-full">
        <h2
          class="text-xs sm:text-base md:text-xl lg:text-2xl 3xl:text-3xl 4xl:text-4xl ml-1"
          data-i18n="greeting"
        >
          {t.greeting}
        </h2>
        <h1
          class="text-4xl sm:text-6xl md:text-7xl lg:text-8xl 3xl:text-9xl font-bold text-transparent bg-clip-text bg-gradient-to-br from-indigo-600 from-40% via-primary via-60% to-green-600 dark:bg-gradient-to-br dark:from-green-600 dark:from-40% dark:via-primary dark:via-80% dark:to-indigo-600"
        >
          Daniel Fernando
        </h1>
      </div>
      <div class="h-full flex flex-col items-end sm:flex-row sm:items-center gap-4">
        <div class="flex items-center">
          <div class="flex justify-end gap-2">
            <LanguageToggle />
            <DarkModeButton />
          </div>
        </div>
        <Button
        id="cv-download-btn"
        title={t.downloadCv}
        data-i18n="downloadCv"
        href={t.cvLink}
        download={t.cvName}
        class="sm:order-first mt-0 sm:mt-0 btn-portfolio"
        >
          <DownloadIcon class="w-4 h-4" />
        </Button>
      </div>
    </divHead>
    <divBody
      class="flex-1 w-full lg:w-[70%] xl:w-[65%] fhd:w-[60%] lg:mx-auto flex flex-col gap-4 lg:gap-6 fhd:gap-8 justify-center my-auto lg:mt-4 fhd:mt-8"
    >
      <div class="grid grid-cols-2 gap-4 hdplus:gap-6 items-stretch">
        <div
          class="min-h-20 pb-1 col-span-1 text-center dark:bg-dark-foreground/85 rounded-2xl h-full w-full items-center justify-center flex flex-col "
        >
          <h1
            class="text-xl sm:text-2xl md:text-3xl lg:text-3xl hdplus:text-4xl fhd:text-6xl font-bold"
          >
            +2
          </h1>
          <h1
            class="text-xs sm:text-sm md:text-base lg:text-sm hdplus:text-base fhd:text-xl px-2"
            data-i18n="yearsExp"
          >
            {t.yearsExp}
          </h1>
        </div>
        
        <div
          class="min-h-20 p-2 col-span-1 text-center dark:bg-dark-foreground/85 rounded-2xl h-full w-full items-center justify-center flex flex-col py-4 fhd:py-6"
        >
          <h1
            class="text-xs sm:text-sm md:text-base lg:text-sm hdplus:text-base fhd:text-xl"
            data-i18n="from"
          >
            {t.from}
          </h1>
          <h1
            class="text-lg sm:text-xl md:text-2xl lg:text-2xl hdplus:text-3xl fhd:text-5xl font-bold"
          >
            Colombia
          </h1>
        </div>

        <div
          class="col-span-2 dark:bg-dark-foreground/85 rounded-2xl h-auto flex flex-col gap-2 hdplus:gap-4 justify-center dark:p-4 fhd:p-5 px-4 min-h-24 fhd:min-h-32"
        >
          <p
            class="max-h-32 hdplus:max-h-40 fhd:max-h-44 overflow-auto text-sm sm:text-base lg:text-base hdplus:text-lg fhd:text-2xl leading-relaxed text-justify"
            data-i18n="bio"
          >
            {t.bio}
          </p>
        </div>
      </div>

      <div class="flex-1 min-h-0 w-full flex flex-col justify-center overflow-hidden" style="border-radius: 1rem;">
        <Roadmap sections={SECTIONS}/>
      </div>
    </divBody>
  </main>
</Base>
