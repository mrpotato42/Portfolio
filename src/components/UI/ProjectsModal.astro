---
import Button from './Button.astro';

// Define project interface and data
interface Project {
  slug: string;
  title: string;
  image: string;
  description: string;
  href: string;
  state: string;
}

const PROJECTS: Project[] = [
  {
    slug: 'Portfolio',
    title: 'Portfolio',
    image: 'images/carrousel1.webp',
    description: 'This is my portfolio, where I showcase my work and projects.',
    href: 'https://mrpotato.netlify.app/',
    state: 'enabled'
  },
  {
    slug: 'k4pital',
    title: 'K4PITAL',
    image: 'images/carrousel2.webp',
    description: 'AI-powered app to manage your finances',
    href: 'https://k4pital.com/',
    state: 'enabled'
  },
  {
    slug: 'Coming Soon',
    title: 'Dolce Amore Mio',
    image: 'images/carrousel3.webp',
    description: 'Coming soon...',
    href: '#',
    state: 'disabled'
  },
];

// Duplicate for infinite scroll effect
const allProjects = [...PROJECTS, ...PROJECTS];

// Generate unique IDs for this component instance
const triggerId = `modal-trigger-${Math.random().toString(36).slice(2, 9)}`;
const dialogId = `modal-dialog-${Math.random().toString(36).slice(2, 9)}`;
---

<!-- Trigger: wraps the slot content and opens the modal on click -->
<div id={triggerId} class="cursor-pointer">
  <slot />
</div>

<!-- Modal Dialog -->
<dialog id={dialogId} class="modal">
  <div class="relative w-[90vw] max-w-4xl max-h-[50vh] sm:max-h-[60vh] lg:max-h-[80vh] backdrop-blur-xl rounded-2xl sm:rounded-3xl p-4 sm:p-6 lg:p-8 overflow-hidden shadow-2xl">
    <div class="flex justify-between items-center mb-4 sm:mb-6 lg:mb-8">
      <h3 class="font-bold text-xl sm:text-2xl lg:text-3xl bg-clip-text text-white/70 dark:text-white">
        Experiences
      </h3>
      <button
        class="btn-modal-close btn btn-circle btn-ghost btn-sm sm:btn-md text-white/50 hover:text-white dark:hover:bg-white/20 transition-all duration-300"
        aria-label="Cerrar"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 sm:h-6 sm:w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="carousel-container">
      <div class="flex gap-3 sm:gap-4 lg:gap-6 w-max overflow-visible animate-infinite-scroll hover:pause">
        {allProjects.map((project, index) => (
          <div
            tabindex="0"
            class={`snap-center project-card cursor-pointer focus:outline-none group relative w-40 h-56 sm:w-56 sm:h-72 lg:w-72 lg:h-96 shrink-0 rounded-xl sm:rounded-2xl overflow-hidden shadow-lg transition-all duration-500 hover:scale-[1.02] sm:hover:scale-105 hover:-translate-y-1 sm:hover:-translate-y-2 hover:pause ${
              index >= PROJECTS.length ? 'hidden md:block' : ''
            }`}
          >
            <!-- Image Background -->
            <div class="absolute inset-0">
              <img
                src={project.image}
                alt={project.title}
                class="w-full h-full object-cover transition-transform duration-700 opacity-20 group-hover:transition-opacity group-hover:opacity-100 group-focus:transition-opacity group-focus:opacity-100 group-hover:scale-110 group-focus:scale-110"
              />
              <div class="absolute inset-0 bg-linear-to-t from-black/100 to-transparent opacity-50 group-hover:opacity-100 group-focus:opacity-100 transition-opacity" />
            </div>

            <!-- Content -->
            <div class="absolute inset-0 p-4 sm:p-6 flex flex-col justify-end translate-y-4 group-hover:translate-y-0 group-focus:translate-y-0 transition-transform duration-500">
              <h4 class="text-xl sm:text-2xl font-bold text-white mb-2 transition-all duration-300 max-h-16 overflow-hidden group-hover:max-h-0 group-hover:opacity-0 group-hover:mb-0 group-focus:max-h-0 group-focus:opacity-0 group-focus:mb-0 lg:group-hover:max-h-20 lg:group-hover:opacity-100 lg:group-hover:mb-2 lg:group-focus:max-h-20 lg:group-focus:opacity-100 lg:group-focus:mb-2">{project.title}</h4>
              <p class="text-white/70 text-xs sm:text-sm line-clamp-3 sm:line-clamp-2 opacity-0 group-hover:opacity-100 group-focus:opacity-100 transition-opacity duration-500 lg:delay-100">
                {project.description}
              </p>
              <div class="mt-3 sm:mt-4 flex gap-2 opacity-0 group-hover:opacity-100 group-focus:opacity-100 transition-opacity duration-500 lg:delay-200">
                <Button
                  title="View Details"
                  href={project.href}
                  disabled={project.state}
                  class="btn-portfolio-details w-fit! bg-white/10! border-white/20! text-white! hover:bg-white/20! text-xs sm:text-sm px-3 py-1 sm:px-4 sm:py-2 h-auto min-h-0"
                />
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</dialog>

<script define:vars={{ triggerId, dialogId }}>
  // Get elements using the unique IDs
  const trigger = document.getElementById(triggerId);
  const dialog = document.getElementById(dialogId);
  const closeBtn = dialog?.querySelector('.btn-modal-close');

  // Open modal on trigger click
  trigger?.addEventListener('click', (e) => {
    e.preventDefault();
    dialog?.showModal();
  });

  // Close modal on button click
  closeBtn?.addEventListener('click', () => {
    dialog?.close();
  });

  // Close modal on backdrop click
  dialog?.addEventListener('click', (e) => {
    if (e.target === dialog) {
      dialog.close();
    }
  });


  // Fix: Prevent cards from "sticking" in hover/focus state on desktop after click
  const cards = dialog?.querySelectorAll('.project-card');
  cards?.forEach(card => {
    card.addEventListener('click', (e) => {
      // Only blur if it's a mouse/fine pointer (Desktop)
      // This preserves the "sticky" tap behavior on Mobile/Tablets
      if (window.matchMedia('(pointer: fine)').matches) {
        // If clicking the button itself, don't blur immediately to avoid flickering
        if (e.target.closest('.btn-portfolio-details')) return;
        
        // Use a small timeout to let the click transition finish, then clear focus
        setTimeout(() => {
          if (document.activeElement === card) {
            card.blur();
          }
        }, 100);
      }
    });
  });
</script>
