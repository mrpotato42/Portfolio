---
import type { HTMLAttributes } from "astro/types";

export interface Props extends HTMLAttributes<"a"> {
  title: string;
  href?: string;
  download?: string;
  target?: string;
  class?: string;
  disabled?: string | boolean;
}

const {
  title,
  href = "#",
  download: rawDownload,
  target: rawTarget,
  disabled,
  class: className,
  ...rest
} = Astro.props;

const download = rawDownload || null;
const target = rawTarget || null;
const isDisabled = disabled === "disabled" || disabled === true;
---

<a 
  href={isDisabled ? undefined : href} 
  download={isDisabled ? undefined : download} 
  target={isDisabled ? undefined : target} 
  class:list={[className, { "opacity-50 pointer-events-none grayscale cursor-not-allowed": isDisabled }]}
  aria-disabled={isDisabled}
  {...rest}
>
  {title}
</a>
